{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/v1/(.*)", "destination": "/api/[...slug]" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/[...slug].ts": {
      "memory": 512,
      "maxDuration": 10
    },
    "api/cron/morning-checkin-reminder.ts": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/cron/snapshot-daily-challenges.ts": {
      "memory": 512,
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/morning-checkin-reminder",
      "schedule": "0 23 * * *"
    },
    {
      "path": "/api/cron/snapshot-daily-challenges",
      "schedule": "55 15 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(self), geolocation=(self), microphone=()" }
      ]
    }
  ]
}
