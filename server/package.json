{
  "name": "yanyan-server",
  "version": "0.0.1",
  "private": true,
  "description": "Yanyan 后端 — Node.js + Fastify + PostgreSQL,部署阿里云华东",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn src/server.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src tests --ext .ts",
    "typecheck": "tsc --noEmit",
    "migrate": "ts-node src/db/migrate.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "@types/web-push": "^3.6.4",
    "@vercel/node": "^3.0.0",
    "fastify": "^4.24.0",
    "jose": "^5.2.0",
    "pg": "^8.11.0",
    "web-push": "^3.6.7",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.10.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.50.0",
    "jest": "^29.6.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.0"
  }
}
