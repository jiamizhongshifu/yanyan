# Yanyan 后端环境变量样例
# Vercel 部署时在项目 Settings → Environment Variables 配置

# 服务
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Supabase
SUPABASE_URL=https://CHANGE_ME.supabase.co
SUPABASE_ANON_KEY=CHANGE_ME_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME_SERVICE_ROLE
# Supabase JWT 密钥(Supabase 项目 Settings → API → JWT Settings)
SUPABASE_JWT_SECRET=CHANGE_ME_JWT_SECRET

# Postgres (从 Supabase 项目 Settings → Database → Connection String 复制)
# 必须含 ?sslmode=require
DATABASE_URL=postgresql://postgres:CHANGE_ME@db.CHANGE_ME.supabase.co:5432/postgres?sslmode=require

# KMS 主密钥(envelope encryption)
# 本地开发使用 LocalKmsStub,KMS_MODE=local;生产 KMS_MODE=aliyun + KMS_KEY_ID(PMF 后迁阿里云 KMS 时使用)
KMS_MODE=local
KMS_LOCAL_MASTER_KEY=CHANGE_ME_64_HEX_CHARS_REPRESENTING_32_BYTES_FOR_AES256
# KMS_KEY_ID=alias/yanyan-master  # 阿里云 KMS 时使用

# 食物图片存储(Supabase Storage,bucket 由 supabase migration 建立)
SUPABASE_STORAGE_FOOD_BUCKET=food-photos
SUPABASE_STORAGE_PDF_BUCKET=profile-pdf
