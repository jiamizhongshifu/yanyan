# Yanyan 后端环境变量样例
# 部署到阿里云华东时,复制为 .env 并替换真实值

# 服务
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# PostgreSQL (阿里云 RDS 华东)
DATABASE_URL=postgres://yanyan:CHANGE_ME@localhost:5432/yanyan_dev

# Redis (阿里云 Redis 华东)
REDIS_URL=redis://localhost:6379

# 阿里云 KMS 主密钥(envelope encryption)
# 本地开发使用 LocalKmsStub,KMS_MODE=local;生产 KMS_MODE=aliyun + KMS_KEY_ID
KMS_MODE=local
KMS_LOCAL_MASTER_KEY=CHANGE_ME_64_HEX_CHARS_REPRESENTING_32_BYTES_FOR_AES256
# KMS_KEY_ID=alias/yanyan-master  # 阿里云 KMS 时使用

# OSS (食物图片 / PDF 存储)
OSS_REGION=cn-hangzhou
OSS_BUCKET=yanyan-private
OSS_ACCESS_KEY_ID=CHANGE_ME
OSS_ACCESS_KEY_SECRET=CHANGE_ME
