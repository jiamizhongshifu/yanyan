/* Yanyan 全局样式
 *
 * 设计语言:中医发物 + 数据简语,无人格(plan Key Decisions)
 * 主色:暖米白(背景)、墨黑(文字)、 火分四档专属配色
 *
 * 后续 U10 主屏 / U6 拍照结果页都从这里引用基础变量
 */

page {
  background-color: #F7F4EE; /* 米白 */
  color: #2A2A2A;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Source Han Sans', sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 火分四档配色(占位,U8 / U10 阶段精调) */
.fire-level-ping  { color: #4A8B6F; } /* 平 */
.fire-level-mild  { color: #C9A227; } /* 微火 */
.fire-level-mid   { color: #D9762C; } /* 中火 */
.fire-level-high  { color: #B43A30; } /* 大火 */

/* 引用文案样式(典籍 / 现代营养学引用) */
.citation {
  font-size: 22rpx;
  color: #7A7A7A;
}

/* 通用容器 */
.container {
  padding: 32rpx;
}
