/* 同意页样式 */

.container { padding: 32rpx 28rpx 48rpx; }

.header { margin-bottom: 32rpx; }
.header .title { font-size: 40rpx; font-weight: 600; color: #2A2A2A; }
.header .subtitle { font-size: 26rpx; color: #5A5A5A; line-height: 1.6; margin-top: 16rpx; }

.scope-list { background: #FFFFFF; border-radius: 16rpx; padding: 8rpx 24rpx; }
.scope-item { display: flex; align-items: flex-start; padding: 24rpx 0; border-bottom: 2rpx solid #EEE; }
.scope-item:last-child { border-bottom: none; }
.scope-text { flex: 1; margin-left: 16rpx; }
.scope-label { font-size: 30rpx; font-weight: 500; color: #2A2A2A; }
.scope-desc { font-size: 24rpx; color: #6A6A6A; line-height: 1.55; margin-top: 8rpx; }

.error { color: #B43A30; font-size: 26rpx; margin-top: 24rpx; padding: 16rpx 24rpx; background: #FFF1EE; border-radius: 12rpx; }

.footer { margin-top: 40rpx; }
.policy-link { font-size: 26rpx; color: #4A8B6F; text-align: center; margin-bottom: 24rpx; text-decoration: underline; }
.submit-btn {
  background: #2A2A2A;
  color: #FFFFFF;
  font-size: 30rpx;
  border-radius: 64rpx;
}
.submit-btn[disabled] { opacity: 0.5; }
