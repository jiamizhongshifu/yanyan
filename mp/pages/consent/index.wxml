<view class="container">
  <view class="header">
    <view class="title">敏感个人信息处理同意</view>
    <view class="subtitle">炎炎消防队基于《个人信息保护法》第二十八条,对以下 5 类敏感个人信息逐项征求同意。任意一项不勾选,该类数据不会被采集 — 但部分核心功能将不可用。</view>
  </view>

  <view class="scope-list">
    <view wx:for="{{scopes}}" wx:key="key" class="scope-item">
      <checkbox
        checked="{{item.checked}}"
        data-scope="{{item.key}}"
        bindtap="onScopeChange"
      />
      <view class="scope-text">
        <view class="scope-label">{{item.label}}</view>
        <view class="scope-desc">{{item.description}}</view>
      </view>
    </view>
  </view>

  <view wx:if="{{errorMessage}}" class="error">{{errorMessage}}</view>

  <view class="footer">
    <view class="policy-link" bindtap="onPrivacyPolicyTap">查看完整《隐私政策》</view>
    <button
      class="submit-btn"
      bindtap="onSubmit"
      disabled="{{submitting}}"
    >
      {{submitting ? '提交中...' : '我已阅读并同意以上 5 项'}}
    </button>
  </view>
</view>
