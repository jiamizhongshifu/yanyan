.container { padding: 48rpx 32rpx; }
.title { font-size: 44rpx; font-weight: 600; color: #2A2A2A; }
.hint { font-size: 26rpx; color: #6A6A6A; margin-top: 16rpx; margin-bottom: 32rpx; }
.choices { display: flex; flex-direction: column; gap: 16rpx; }
.choice {
  padding: 28rpx 32rpx;
  border-radius: 16rpx;
  background: #FFFFFF;
  font-size: 30rpx;
  border: 2rpx solid #E8E8E8;
}
.choice-selected { border-color: #2A2A2A; background: #2A2A2A; color: #FFFFFF; }
.next-btn {
  margin-top: 64rpx;
  background: #2A2A2A;
  color: #FFFFFF;
  border-radius: 64rpx;
}
.next-btn[disabled] { opacity: 0.4; }
