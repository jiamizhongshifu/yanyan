<view class="container">
  <view class="reading">
    <view class="reading-label">看起来你近期偏</view>
    <view class="reading-level fire-level-{{initialFireLevelLocal === '平' ? 'ping' : initialFireLevelLocal === '微火' ? 'mild' : initialFireLevelLocal === '中火' ? 'mid' : 'high'}}">{{initialFireLevelLocal}}</view>
    <view class="reading-hint">这是基于你刚选的症状频次得出的初步判断。完成下方授权后,我们会在每天早上根据你昨天的饮食和身体反应给你一个新读数。</view>
  </view>

  <view class="consent-block">
    <view class="consent-title">敏感个人信息处理同意(《个保法》第二十八条)</view>
    <view class="scope-list">
      <view wx:for="{{scopes}}" wx:key="key" class="scope-item">
        <checkbox checked="{{item.checked}}" data-scope="{{item.key}}" bindtap="onScopeChange" />
        <text class="scope-label">{{item.label}}</text>
      </view>
    </view>
    <view class="consent-foot">勾选 5 项即视为对此 5 类敏感个人信息的处理单独同意。任意一项不勾选将无法使用核心功能。完整文本见 <navigator url="/pages/privacy-policy/index" class="link">《隐私政策》</navigator>。</view>
  </view>

  <view wx:if="{{errorMessage}}" class="error">{{errorMessage}}</view>

  <button class="submit-btn" bindtap="onSubmit" disabled="{{submitting}}">
    {{submitting ? '提交中...' : '我已阅读并同意 5 项 → 下一步'}}
  </button>
</view>
