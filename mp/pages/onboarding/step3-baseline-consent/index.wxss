.container { padding: 48rpx 32rpx; }

.reading { margin-bottom: 48rpx; }
.reading-label { font-size: 28rpx; color: #6A6A6A; }
.reading-level { font-size: 96rpx; font-weight: 600; line-height: 1.1; margin-top: 8rpx; }
.reading-hint { font-size: 26rpx; color: #5A5A5A; margin-top: 16rpx; line-height: 1.6; }

.consent-block { background: #FFFFFF; border-radius: 16rpx; padding: 24rpx; }
.consent-title { font-size: 30rpx; font-weight: 500; margin-bottom: 16rpx; color: #2A2A2A; }
.scope-list { display: flex; flex-direction: column; gap: 12rpx; }
.scope-item { display: flex; align-items: center; padding: 8rpx 0; }
.scope-label { margin-left: 12rpx; font-size: 28rpx; color: #2A2A2A; }
.consent-foot { font-size: 22rpx; color: #6A6A6A; margin-top: 16rpx; line-height: 1.55; }
.link { color: #4A8B6F; text-decoration: underline; display: inline; }

.error { color: #B43A30; font-size: 26rpx; margin-top: 24rpx; padding: 16rpx; background: #FFF1EE; border-radius: 12rpx; }
.submit-btn { margin-top: 48rpx; background: #2A2A2A; color: #FFFFFF; font-size: 30rpx; border-radius: 64rpx; }
.submit-btn[disabled] { opacity: 0.5; }
